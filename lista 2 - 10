<!DOCTYPE html>
<html>
<head>
<title>Sistema de estatísticas</title>
</head>
<body>
<h1>Sistema de estatísticas</h1>
<button onclick="inserirNumero()">Inserir número</button>
<button onclick="mostrarMaior()">Mostrar maior</button>
<button onclick="mostrarMenor()">Mostrar menor</button>
<script src="script.js"></script>
</body>
</html>

let numeros = []
function inserirNumero(){
    let numero = Number(prompt("Digite um número"))
    numeros.push(numero)
}
function mostrarMaior(){
    let maior = numeros[0]
    for (let i = 1; i < numeros.length; i++){
        if (numeros[i] > maior){
            maior = numeros[i]
        }
    }
    alert("Maior número - " + maior)
}
function mostrarMenor(){
    let menor = numeros[0]
    for (let i = 1; i < numeros.length; i++){
        if (numeros[i] < menor){
            menor = numeros[i]
        }
    }
    alert("Menor número - " + menor)
}
