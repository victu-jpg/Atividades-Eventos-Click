function frase() {
    let frases = [
      "Rapaziada, eu tava com uma loira, uma morena e uma ruiva... Sabe o que eu fiz? Mandei a bola lá na gavetaaaaa! Golaço do Marcelinhoooo! Vem com o pai!"
    ];
    let sorteio = Math.floor(Math.random() * frases.length);
    alert(frases[sorteio]);
}
