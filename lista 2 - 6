<!DOCTYPE html>
<html>
<head>
<title>Cadastro simples</title>
</head>
<body>
<h1>Cadastro simples</h1>
<button onclick="adicionarNome()">Adicionar nome</button>
<button onclick="mostrarNomes()">Mostrar nomes</button>
<button onclick="contarNomes()">Contar nomes</button>
<script src="script.js"></script>
</body>
</html>


let nomes = []
function adicionarNome(){
    let nome = prompt("Digite um nome")
    nomes.push(nome)
}
function mostrarNomes(){
    alert(nomes.join("\n"))
}
function contarNomes(){
    alert("Quantidade de nomes -  " + nomes.length)
}
