<!DOCTYPE html>
<html>
<head>
<title>Detector de mouse</title>
</head>
<body>
<h1>Detector de mouse</h1>
<button onmouseover="mouseChegou()">Botão 1</button>
<button onmouseout="mouseFoiEmbora()">Botão 2</button>
<button onclick="clicouEmMim()">Botão 3</button>
<script src="script.js"></script>
</body>
</html>

function mouseChegou(){
    alert("O mouse chegou")
}
function mouseFoiEmbora(){
    alert("O mouse foi embora")
}
function clicouEmMim(){
    alert("Você clicou em mim")
}
